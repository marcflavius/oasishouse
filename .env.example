# Frontend (Vite) — safe to expose in the browser bundle
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The following are set as Edge Function secrets, NOT in this .env file.
# Set them with:
#   supabase secrets set RESEND_API_KEY=... RESEND_FROM=... OTP_SECRET=... ADMIN_PASSWORD=...
#
# SUPABASE_URL                 (auto-provided by Supabase runtime)
# SUPABASE_SERVICE_ROLE_KEY    (auto-provided by Supabase runtime)
# RESEND_API_KEY               your Resend API key
# RESEND_FROM                  e.g. "Oasis House <casting@yourdomain.com>"
# OTP_SECRET                   random string (>=32 chars) used to HMAC-sign OTP challenges
# ADMIN_PASSWORD               password for the /admin page
